# Event by Jaleco — environment variables
#
# Copy this file to `.env.local` and fill in real values for production
# builds. Both variables are optional: when empty, the related markup
# (analytics script, Google Search Console verification meta) is omitted
# from the rendered HTML.

# Google Analytics 4 measurement ID, e.g. "G-XXXXXXXXXX".
# Find it at https://analytics.google.com → Admin → Data streams.
NEXT_PUBLIC_GA4_ID=

# Google Search Console verification token (the value of the
# `content` attribute of the verification <meta> tag, NOT the full tag).
# Find it at https://search.google.com/search-console → Settings →
# Ownership verification → HTML tag.
NEXT_PUBLIC_GSC_VERIFICATION=
